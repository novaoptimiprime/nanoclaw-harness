+/**
+ * Count distinct `node_id`s in a trace JSONL, excluding entry/exit anchors.
+ *
+ * This matches Nova's `displayCount` semantic ([ViewerClient.tsx] computes
+ * the same count from loaded events). Used by the on-exit rewrite below to
+ * replace the pessimistic `node_count: 1` written at entry time.
+ */
+function countDistinctNonAnchorNodes(jsonlPath: string): number {
+  let raw: string;
+  try {
+    raw = fs.readFileSync(jsonlPath, 'utf8');
+  } catch {
+    return 0;
+  }
+  const nodes = new Set<string>();
+  for (const line of raw.split(/\r?\n/)) {
+    if (!line.trim()) continue;
+    try {
+      const e = JSON.parse(line) as { event?: unknown; node_id?: unknown };
+      if (e.event === 'entry' || e.event === 'exit') continue;
+      if (typeof e.node_id === 'string') nodes.add(e.node_id);
+    } catch {
+      /* skip malformed */
+    }
+  }
+  return nodes.size;
+}
+
+/**
+ * Rewrite the matching `index.jsonl` line for `traceId` with a new
+ * `node_count`. Atomic via tmp+rename so a crash mid-rewrite leaves the
+ * original file intact. Silent no-op if the index is missing or has no
+ * matching line — this fix is best-effort and must never break tracing.
+ */
+function rewriteIndexNodeCount(tracesRoot: string, traceId: string, newCount: number): void {
+  const indexPath = path.join(tracesRoot, 'index.jsonl');
+  let raw: string;
+  try {
+    raw = fs.readFileSync(indexPath, 'utf8');
+  } catch {
+    return;
+  }
+  const lines = raw.split(/\r?\n/);
+  let modified = false;
+  for (let i = 0; i < lines.length; i++) {
+    const line = lines[i];
+    if (!line || !line.trim()) continue;
+    try {
+      const entry = JSON.parse(line) as Record<string, unknown> & { trace_id?: unknown };
+      if (entry.trace_id !== traceId) continue;
+      entry.node_count = newCount;
+      lines[i] = JSON.stringify(entry);
+      modified = true;
+      // Don't break: tolerate (rare) duplicate index lines for the same trace.
+    } catch {
+      /* skip malformed */
+    }
+  }
+  if (!modified) return;
+  const tmp = indexPath + '.tmp';
+  try {
+    fs.writeFileSync(tmp, lines.join('\n'));
+    fs.renameSync(tmp, indexPath);
+  } catch {
+    /* swallow — tracing must never break the host */
+  }
+}
