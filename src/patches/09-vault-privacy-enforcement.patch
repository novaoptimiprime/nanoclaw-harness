diff --git a/src/modules/mount-security/mount-security.test.ts b/src/modules/mount-security/mount-security.test.ts
new file mode 100644
index 0000000..bb54642
--- /dev/null
+++ b/src/modules/mount-security/mount-security.test.ts
@@ -0,0 +1,84 @@
+import { describe, it, expect } from 'vitest';
+import fs from 'fs';
+import os from 'os';
+import path from 'path';
+
+import { validateMount, type MountAllowlist } from './index.js';
+
+function makeAllowlist(roots: MountAllowlist['allowedRoots']): MountAllowlist {
+  return { allowedRoots: roots, blockedPatterns: [] };
+}
+
+describe('validateMount — per-agent ownership enforcement (Vault privacy)', () => {
+  const tmpRoot = fs.mkdtempSync(path.join(os.tmpdir(), 'mount-security-test-'));
+  const manuVault = path.join(tmpRoot, 'TechAgent', 'Vault');
+  const vedaVault = path.join(tmpRoot, 'ResearchAssistant', 'Vault');
+  const sharedDir = path.join(tmpRoot, 'MasterMind');
+  fs.mkdirSync(manuVault, { recursive: true });
+  fs.mkdirSync(vedaVault, { recursive: true });
+  fs.mkdirSync(sharedDir, { recursive: true });
+
+  const allowlist = makeAllowlist([
+    { path: manuVault, allowReadWrite: true, ownedBy: 'manu', description: 'Manu Vault' },
+    { path: vedaVault, allowReadWrite: true, ownedBy: 'veda', description: 'Veda Vault' },
+    { path: sharedDir, allowReadWrite: true, description: 'Shared infra (no ownedBy)' },
+  ]);
+
+  it('rejects cross-agent vault mount: Veda trying to mount Manu Vault', () => {
+    const result = validateMount(
+      { hostPath: manuVault, containerPath: 'foreign-vault', readonly: false },
+      'Veda',
+      allowlist,
+    );
+    expect(result.allowed).toBe(false);
+    expect(result.reason).toMatch(/Cross-agent ownership violation/);
+    expect(result.reason).toMatch(/owned by "manu"/);
+    expect(result.reason).toMatch(/agent "Veda"/);
+    expect(result.reason).toMatch(/MasterMind\/Vault\.md/);
+  });
+
+  it('accepts a vault mount when the requesting agent matches ownedBy', () => {
+    const result = validateMount(
+      { hostPath: manuVault, containerPath: 'own-vault', readonly: false },
+      'Manu',
+      allowlist,
+    );
+    expect(result.allowed).toBe(true);
+    expect(result.realHostPath).toBe(fs.realpathSync(manuVault));
+  });
+
+  it('matches case-insensitively on the agent name (group name "MANU" → slug "manu")', () => {
+    const result = validateMount(
+      { hostPath: manuVault, containerPath: 'own-vault', readonly: false },
+      'MANU',
+      allowlist,
+    );
+    expect(result.allowed).toBe(true);
+  });
+
+  it('rejects when no agent name is provided and the root has ownedBy set', () => {
+    const result = validateMount(
+      { hostPath: manuVault, containerPath: 'foreign-vault', readonly: false },
+      undefined,
+      allowlist,
+    );
+    expect(result.allowed).toBe(false);
+    expect(result.reason).toMatch(/Cross-agent ownership violation/);
+  });
+
+  it('allows shared infrastructure (no ownedBy) for any agent', () => {
+    const veda = validateMount(
+      { hostPath: sharedDir, containerPath: 'shared', readonly: true },
+      'Veda',
+      allowlist,
+    );
+    expect(veda.allowed).toBe(true);
+
+    const manu = validateMount(
+      { hostPath: sharedDir, containerPath: 'shared', readonly: true },
+      'Manu',
+      allowlist,
+    );
+    expect(manu.allowed).toBe(true);
+  });
+});
