+// MCP-tool invocations (mcp__<server>__<tool>) emit a paired call/result so Nova
+// can render hops between the agent's Soul and the MCP server it talked to.
+// v1 emitted these from container-runner; v2's agent-runner extraction dropped
+// the branch (was claimed in line-91 comment, never wired). Restored 2026-05-02
+// — gap #16. Server names with underscores (e.g. mcp__claude_in_chrome__find)
+// require the non-greedy first capture.
+const MCP_TOOL_RE = /^mcp__(.+?)__(.+)$/;
+const MCP_PAYLOAD_LIMIT = 4096;
+
+function emitMcpEvent(
+  kind: 'call' | 'result',
+  toolName: string,
+  payload: unknown,
+  isError?: boolean,
+): void {
+  const traceId = readSentinel(TRACE_ID_FILE);
+  const agent = readSentinel(TRACE_AGENT_FILE);
+  if (!traceId || !agent) return;
+  const m = MCP_TOOL_RE.exec(toolName);
+  if (!m) return;
+  const server = m[1];
+  const tool = m[2];
+  let snippet: unknown = payload;
+  try {
+    const s = JSON.stringify(payload);
+    if (s && s.length > MCP_PAYLOAD_LIMIT) snippet = s.slice(0, MCP_PAYLOAD_LIMIT) + '…[truncated]';
+  } catch {
+    /* non-serializable; pass through */
+  }
+  appendTraceEvent({
+    trace_id: traceId,
+    timestamp: new Date().toISOString(),
+    agent,
+    node_id: `${agent}:mcp:${server}:${tool}`,
+    event: kind === 'call' ? 'mcp_call' : 'mcp_result',
+    related_node_id: null,
+    server,
+    tool,
+    kind: 'write',
+    ...(kind === 'call' ? { args: snippet } : { response: snippet, isError: !!isError }),
+  });
+}
+
